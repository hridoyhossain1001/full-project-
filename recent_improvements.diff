+function capigw_ajax_rate_limited() {
+    $ip = capigw_get_real_ip();
+    if ( empty( $ip ) ) {
+        return false;
+    }
+
+    $limit      = 120;
+    $window     = 60;
+    $cache_key  = 'capigw_ajax_rate_' . md5( $ip );
+    $hit_count  = (int) get_transient( $cache_key );
+
+    if ( $hit_count >= $limit ) {
+        return true;
+    }
+
+    set_transient( $cache_key, $hit_count + 1, $window );
+    return false;
+}
