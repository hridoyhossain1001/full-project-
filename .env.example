DATABASE_URL=postgresql://user:password@localhost:5432/capi_gateway
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_API_KEY=change-me-random-url-safe-token
ENCRYPTION_KEY=change-me-valid-fernet-key

# Optional production hardening
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,*.herokuapp.com
ENABLE_DOCS=false
SKIP_CREATE_ALL=true
ALLOW_LEGACY_PLAINTEXT_TOKENS=false
CAPI_SIGNATURE_WINDOW_SECONDS=300
REQUIRE_WC_WEBHOOK_SIGNATURE=true
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=40
HTTP_TIMEOUT_SECONDS=15.0
EVENT_WORKER_BATCH_SIZE=25
EVENT_WORKER_POLL_SECONDS=1.0
EVENT_OUTBOX_MAX_ATTEMPTS=8
